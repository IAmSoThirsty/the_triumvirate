# Netlify/Cloudflare Pages Headers Configuration
# For enhanced security and performance

/*
  # Security Headers
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  
  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google-analytics.com https://www.googletagmanager.com https://static.rocket.new https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://static.rocket.new https://application.rocket.new; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
  
  # Cache Control
  Cache-Control: public, max-age=0, must-revalidate

# Static assets with long cache
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

/public/*
  Cache-Control: public, max-age=31536000, immutable

# Service Worker - no cache
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

# Manifest
/public/manifest.json
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json

# HTML files - no cache
/*.html
  Cache-Control: public, max-age=0, must-revalidate
