{
  "name": "the-triumvirate",
  "version": "1.0.2",
  "description": "A comprehensive manifesto and architectural framework exploring the intersection of AI, Humanity, and Technology through ethical AI development, robust security, and transparent knowledge systems.",
  "main": "index.html",
  "dependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-elevation": "^2.0.0",
    "tailwindcss-fluid-type": "^2.0.7"
  },
  "scripts": {
    "build:css": "npx tailwindcss -i ./css/tailwind.css -o ./css/main.css --minify",
    "build:css:dev": "npx tailwindcss -i ./css/tailwind.css -o ./css/main.css",
    "watch:css": "npx tailwindcss -i ./css/tailwind.css -o ./css/main.css --watch",
    "dev": "npm run watch:css",
    "test": "jest",
    "test:lighthouse": "npx @lhci/cli autorun --config=lighthouserc.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest tests/integration.test.js",
    "meta:generate": "node js/meta-generator.js",
    "meta:list": "node js/meta-generator.js --list",
    "validate": "npm run test && npm run test:integration",
    "build": "npm run build:css",
    "serve": "npx http-server -p 8080 -c-1",
    "start": "npm run serve",
    "deploy:preview": "npm run build && npm run serve",
    "audit:security": "npm audit",
    "audit:fix": "npm audit fix",
    "outdated": "npm outdated",
    "clean": "node -e \"const fs=require('node:fs');['node_modules','css/main.css'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "reinstall": "npm run clean && npm install"
  },
  "author": "Jeremy Karrick (Thirsty) <thirstysprojects.com>",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/line-clamp": "^0.1.0",
    "@tailwindcss/typography": "^0.5.16",
    "jest": "^29.7.0"
  }
}